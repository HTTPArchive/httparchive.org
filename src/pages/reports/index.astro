---
import Base from '../../layouts/Base.astro';
import { getReports, getReportUrl } from '../../utils/reports.js';
import { marked } from 'marked';
import '../../styles/reports.css';

const title = 'Reports';
const description = 'List of reports the HTTP Archive Tracks creates to track various aspects of the the web: State of the Web, State of JavaScript, State of Images, Loading Speed, Progressive Web Apps, Accessibility, SEO, Page Weight, Chrome User Experience Report, and Capabilities.';

const reports = getReports();

function renderMarkdown(text: string): string {
  if (!text) return '';
  return marked(text) as string;
}

function getReportGraphicStyle(report: any): string {
  return report.graphic?.bgcolor ? `style="background-color: ${report.graphic.bgcolor}"` : '';
}
---
<Base title={title} description={description}>

  <!-- SVG sprite for report icons (from reports.html) -->
