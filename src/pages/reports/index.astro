    <symbol id="fa-file-image" viewBox="0 0 384 512"><path fill="currentColor" d="M369.9 97.9L286 14C277 5 264.8-.1 252.1-.1H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V131.9c0-12.7-5.1-25-14.1-34zM332.1 128H256V51.9l76.1 76.1zM48 464V48h160v104c0 13.3 10.7 24 24 24h104v288H48zm32-48h224V288l-23.5-23.5c-4.7-4.7-12.3-4.7-17 0L176 352l-39.5-39.5c-4.7-4.7-12.3-4.7-17 0L80 352v64zm48-240c-26.5 0-48 21.5-48 48s21.5 48 48 48 48-21.5 48-48-21.5-48-48-48z"/></symbol>
    <symbol id="fa-stopwatch" viewBox="0 0 448 512"><path fill="currentColor" d="M432 304c0 114.9-93.1 208-208 208S16 418.9 16 304c0-104 76.3-190.2 176-205.5V64h-28c-6.6 0-12-5.4-12-12V12c0-6.6 5.4-12 12-12h120c6.6 0 12 5.4 12 12v40c0 6.6-5.4 12-12 12h-28v34.5c37.5 5.8 71.7 21.6 99.7 44.6l27.5-27.5c4.7-4.7 12.3-4.7 17 0l28.3 28.3c4.7 4.7 4.7 12.3 0 17l-29.4 29.4-.6.6C419.7 223.3 432 262.2 432 304zm-176 36V188.5c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12V340c0 6.6 5.4 12 12 12h40c6.6 0 12-5.4 12-12z"/></symbol>
    <symbol id="fa-cogs" viewBox="0 0 640 512"><path fill="currentColor" d="M512.1 191l-8.2 14.3c-3 5.3-9.4 7.5-15.1 5.4-11.8-4.4-22.6-10.7-32.1-18.6-4.6-3.8-5.8-10.5-2.8-15.7l8.2-14.3c-6.9-8-12.3-17.3-15.9-27.4h-16.5c-6 0-11.2-4.3-12.2-10.3-2-12-2.1-24.6 0-37.1 1-6 6.2-10.4 12.2-10.4h16.5c3.6-10.1 9-19.4 15.9-27.4l-8.2-14.3c-3-5.2-1.9-11.9 2.8-15.7 9.5-7.9 20.4-14.2 32.1-18.6 5.7-2.1 12.1.1 15.1 5.4l8.2 14.3c10.5-1.9 21.2-1.9 31.7 0L552 6.3c3-5.3 9.4-7.5 15.1-5.4 11.8 4.4 22.6 10.7 32.1 18.6 4.6 3.8 5.8 10.5 2.8 15.7l-8.2 14.3c6.9 8 12.3 17.3 15.9 27.4h16.5c6 0 11.2 4.3 12.2 10.3 2 12 2.1 24.6 0 37.1-1 6-6.2 10.4-12.2 10.4h-16.5c-3.6 10.1-9 19.4-15.9 27.4l8.2 14.3c3 5.2 1.9 11.9-2.8 15.7-9.5 7.9-20.4 14.2-32.1 18.6-5.7 2.1-12.1-.1-15.1-5.4l-8.2-14.3c-10.4 1.9-21.2 1.9-31.7 0zm-10.5-58.8c38.5 29.6 82.4-14.3 52.8-52.8-38.5-29.7-82.4 14.3-52.8 52.8z"/></symbol>
    <symbol id="fa-weight" viewBox="0 0 512 512"><path fill="currentColor" d="M448 64h-26c16.4 28.3 26 61 26 96 0 105.9-86.1 192-192 192S64 265.9 64 160c0-35 9.6-67.7 26-96H64C28.7 64 0 92.7 0 128v320c0 35.3 28.7 64 64 64h384c35.3 0 64-28.7 64-64V128c0-35.3-28.7-64-64-64z"/></symbol>
    <symbol id="fa-wrench" viewBox="0 0 512 512"><path fill="currentColor" d="M481.156 200c9.3 0 15.12 10.155 10.325 18.124C466.295 259.992 420.419 288 368 288c-79.222 0-143.501-63.974-143.997-143.079C223.505 65.469 288.548-.001 368.002 0c52.362.001 98.196 27.949 123.4 69.743C496.24 77.766 490.523 88 481.154 88H376l-40 56 40 56h105.156z"/></symbol>
    <symbol id="fa-tachometer-alt" viewBox="0 0 576 512"><path fill="currentColor" d="M75.694 480a48.02 48.02 0 0 1-42.448-25.571C12.023 414.3 0 368.556 0 320 0 160.942 128.942 32 288 32s288 128.942 288 288c0 48.556-12.023 94.3-33.246 134.429A48.018 48.018 0 0 1 500.306 480H75.694z"/></symbol>
    <symbol id="fa-users" viewBox="0 0 640 512"><path fill="currentColor" d="M320 64c57.99 0 105 47.01 105 105s-47.01 105-105 105-105-47.01-105-105S262.01 64 320 64z"/></symbol>
    <symbol id="fa-searchengin" viewBox="0 0 460 512"><path fill="currentColor" d="M220.6 130.3l-67.2 28.2V43.2L98.7 233.5l54.7-24.2v130.3l67.2-209.3z"/></symbol>
  </svg>

  <section class="container">
    <div class="row">
      <div class="container">
        <h1>All Reports</h1>
      </div>
    </div>
    {reports.map((report, index) => {
      const url = getReportUrl(report);
      const altClass = index % 2 === 1 ? 'alt' : '';
      return (
        <div class="report row">
          <div class={`container ${altClass}`}>
            <div class="col-lg-5 col-sm-6 col-md-6 col-xs-12 hidden-xs">
              <a href={url} title={report.name}>
                {report.graphic ? (
                  <div class="figure report-graphic" style={report.graphic.bgcolor ? `background-color: ${report.graphic.bgcolor}` : ''}>
                    {report.graphic.secondary && (
                      report.graphic.secondary.icon ? (
                        <svg class={`svg-inline--fa ${report.graphic.secondary.width} secondary-icon`} style={`color: ${report.graphic.secondary.color};`} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                          <use xlinkHref={`#${report.graphic.secondary.icon}`}></use>
                        </svg>
                      ) : (
                        <div class="secondary-icon" style={`color: ${report.graphic.secondary.color}`} aria-hidden="true">
                          {report.graphic.secondary.text}
                        </div>
                      )
                    )}
                    {report.graphic.primary.icon ? (
                      <svg class={`svg-inline--fa ${report.graphic.primary.width} primary-icon`} style={`color: ${report.graphic.primary.color};`} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                        <use xlinkHref={`#${report.graphic.primary.icon}`}></use>
                      </svg>
                    ) : (
                      <div class="primary-icon" style={`color: ${report.graphic.primary.color}`} aria-hidden="true">
                        {report.graphic.primary.text}
                      </div>
                    )}
                  </div>
                ) : (
                  <div class="figure report-graphic default-report"></div>
                )}
              </a>
            </div>
            <div class="col-lg-7 col-sm-6 col-md-6 col-xs-12">
              <h2>
                <a href={url}>{report.name}</a>
              </h2>
              {report.summary && <div set:html={renderMarkdown(report.summary)} />}
              <a href={url} class="btn">
                View the {report.name}{!report.name.endsWith('Report') ? ' Report' : ''}
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </section>
</Base>
