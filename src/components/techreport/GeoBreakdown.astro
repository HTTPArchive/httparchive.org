---
/**
 * GeoBreakdown Astro component — translates templates/techreport/components/geo_breakdown.html
 */
export interface Props {
  geoBreakdown: {
    id: string;
    description: string;
  };
}

const { geoBreakdown } = Astro.props;
---
<div
  id={`section-${geoBreakdown.id}`}
  class="geo-breakdown-wrapper hidden"
  data-id={geoBreakdown.id}
  data-component="geoBreakdown"
  data-client="mobile"
>
  <div class="component-heading-wrapper">
    <div class="component-heading">
      <h3>
        <a href={`#section-${geoBreakdown.id}`} class="anchor">
          <span data-slot="geo-title-metric">Core Web Vitals</span> geographic breakdown
        </a>
      </h3>
      <p class="descr">{geoBreakdown.description}</p>
    </div>
  </div>

  <div class="geo-breakdown-controls">
    <div class="geo-breakdown-meta">
      <h4 class="heading">Latest data: <span data-slot="geo-timestamp"></span></h4>
      <ul class="meta">
        <li>Client: <span data-slot="client">Mobile</span></li>
        <li>Rank: <span data-slot="rank">ALL</span></li>
        <li>Technology: <span data-slot="tech">ALL</span></li>
      </ul>
    </div>
  </div>

  <div id={`${geoBreakdown.id}-table`}></div>
</div>
