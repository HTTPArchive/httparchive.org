---
/**
 * Tech Report Filters Component — translates templates/techreport/templates/filters.html
 */
---
<form id="page-filters">
  <div>
    <fieldset class="technology-filters" data-component="combobox" data-id="tech-selector">
      <legend class="form-title">Choose a dataset</legend>
      <label id="combobox-tech-label">Technology</label>
      <div
        class="combobox-wrapper"
        role="combobox"
        aria-expanded="false"
        aria-haspopup="listbox"
        aria-owns="listbox-tech"
      >
        <input
          aria-autocomplete="list"
          aria-activedescendant=""
          aria-labelledby="combobox-tech-label"
          aria-describedby="combobox-tech-selected"
          type="text"
          placeholder="Search a technology"
          disabled
        />
        <div aria-multiselectable="true" role="listbox" id="listbox-tech" class="hidden"></div>
      </div>
      <div data-component="submit-options" style="display: none"></div>
      <ul id="combobox-tech-selected"></ul>
    </fieldset>

    <fieldset class="lens">
      <legend class="sr-only">Lens</legend>

      <div class="default-dropdown-group">
        <label for="geo">Geo</label>
        <div class="default-dropdown-wrapper">
          <select name="geo" id="geo" class="default-dropdown" disabled>
            <option value="ALL" selected="true">ALL</option>
          </select>
        </div>
      </div>

      <div class="default-dropdown-group">
        <label for="rank">Rank</label>
        <div class="default-dropdown-wrapper">
          <select name="rank" id="rank" class="default-dropdown" disabled>
            <option value="ALL" selected="true">ALL</option>
          </select>
        </div>
      </div>
    </fieldset>

    <fieldset class="date-range">
      <legend class="sr-only">Date range</legend>
      <div class="default-dropdown-group">
        <label for="startDate">Start Date</label>
        <div class="default-dropdown-wrapper">
          <select name="startDate" id="startDate" class="default-dropdown" disabled>
            <option value=""></option>
          </select>
        </div>
      </div>

      <div class="default-dropdown-group">
        <label for="endDate">End Date</label>
        <div class="default-dropdown-wrapper">
          <select name="endDate" id="endDate" class="default-dropdown" disabled>
            <option value=""></option>
          </select>
        </div>
      </div>
    </fieldset>
  </div>
  <button type="submit" id="submit-form" class="main-btn">Update</button>

  <ul class="meta">
    <li class="client">
      Client: <span data-slot="client">Mobile</span>
    </li>
    <li>
      Geo: <span data-slot="geo">ALL</span>
    </li>
    <li>
      Rank: <span data-slot="rank">ALL</span>
    </li>
    <li class="tech-meta-item">
      Technology: <span data-slot="tech">ALL</span>
    </li>
  </ul>
</form>

<template id="filter-option">
  <option value="Option">Option</option>
</template>

<template id="tech-selector">
  <div class="tech-selector-group" data-tech="tech-new">
    <div class="tech-selector default-dropdown-group">
      <label class="tech default-dropdown-label">Technology</label>
      <div class="default-dropdown-wrapper">
        <select name="tech" class="default-dropdown tech" data-selected="ALL" id="tech-new" disabled>
          <option value="ALL" selected="true">ALL</option>
        </select>
      </div>
    </div>
    <button class="remove-tech hidden" data-tech="tech-new" type="button">
      <img src="/static/img/close-filters.svg" alt="Remove option" width="12px" height="12px" />
    </button>
  </div>
</template>
