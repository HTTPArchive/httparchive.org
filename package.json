{
  "name": "httparchive.org",
  "version": "0.0.1",
  "description": "Track how the web is built.",
  "main": "index.html",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HTTPArchive/httparchive.org.git"
  },
  "author": "Rick Viscomi",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/HTTPArchive/httparchive.org/issues"
  },
  "homepage": "https://github.com/HTTPArchive/httparchive.org#readme",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "astro:build": "astro build",
    "astro:dev": "astro dev",
    "watch": "webpack --config webpack.config.js --mode production --watch",
    "generate": "node ./tools/generate",
    "start": "npm run build && npm run timestamps && npm run generate && npm run astro:build && node server.js",
    "stage": "npm run build && npm run timestamps && npm run generate && npm run astro:build && echo \"Y\" | gcloud app deploy --project httparchive --no-promote --version=staging",
    "testdeploy": "npm run build && npm run timestamps && npm run generate && npm run astro:build && echo \"Y\" | gcloud app deploy --project httparchive --no-promote",
    "deploy": "./tools/scripts/deploy.sh",
    "timestamps": "node ./tools/generate/generate_timestamps",
    "lint": "run-script-os",
    "lint:darwin:linux": "docker container run -it --rm -v \"$PWD\":/app -w /app --entrypoint=./tools/scripts/run_linter_locally.sh github/super-linter",
    "lint:win32": "docker container run --rm -v \"%cd%\":/app -w /app/ --entrypoint=./tools/scripts/run_linter_locally.sh github/super-linter",
    "test": "node ./tools/test"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "ejs": "6.0.1",
    "fs-extra": "11.3.5",
    "highcharts": "11.4.8",
    "marked": "^18.0.5",
    "node-fetch": "3.3.2",
    "recursive-readdir": "2.2.3",
    "run-script-os": "1.1.6",
    "web-vitals": "5.3.0",
    "webpack": "5.108.1",
    "webpack-cli": "7.1.0",
    "xml-js": "1.6.11"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "express": "^5.2.1"
  }
}
